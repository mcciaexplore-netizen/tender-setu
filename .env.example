# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=tendersetu
POSTGRES_PASSWORD=tendersetu_dev_password
POSTGRES_DB=tendersetu
POSTGRES_PORT=5432

# ─── Prisma ──────────────────────────────────────────────────────────────────
